{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@casino/engine": ["../../packages/engine/src/index.ts"],
      "@casino/core": ["../../packages/core/src/index.ts"],
      "@casino/llm": ["../../packages/llm/src/index.ts"]
    }
  },
  "include": ["src", "api", "vite.config.ts"]
}
